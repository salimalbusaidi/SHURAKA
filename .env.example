# ============================================================
# شركاء — Environment Variables Template
# نموذج متغيرات البيئة — لا تضع قيمًا حقيقية هنا
# انسخ هذا الملف إلى .env وأضف قيمك الحقيقية
# ============================================================

# ─────────────────────────────────────────────────────────────
# Supabase (OnSpace Cloud / Supabase)
# الحصول عليها من: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# مفتاح الخدمة (للاستخدام في Edge Functions فقط — لا تضعه في Frontend)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key (Edge Functions only)

# ─────────────────────────────────────────────────────────────
# التطبيق العام
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://shuraka.app
EXPO_PUBLIC_APP_NAME=شركاء
EXPO_PUBLIC_APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────
# Stripe — الدفع والاشتراكات
# الحصول عليها من: dashboard.stripe.com → Developers → API Keys
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# STRIPE_SECRET_KEY=sk_live_your_secret_key (Edge Functions only)
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret (Edge Functions only)

# Stripe Price IDs — الحصول عليها من Stripe Dashboard → Products
EXPO_PUBLIC_STRIPE_PRICE_STARTER=price_your_starter_plan_price_id
EXPO_PUBLIC_STRIPE_PRICE_GROWTH=price_your_growth_plan_price_id
EXPO_PUBLIC_STRIPE_PRICE_PLUS=price_your_plus_plan_price_id

# ─────────────────────────────────────────────────────────────
# البريد الإلكتروني — Email Service
# يمكن استخدام: SendGrid / Resend / Mailgun / SMTP
# ─────────────────────────────────────────────────────────────
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=your_email_api_key_here
# EMAIL_FROM=noreply@shuraka.app
# EMAIL_FROM_NAME=شركاء

# SendGrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Resend
# RESEND_API_KEY=re_your_resend_api_key

# SMTP مخصص
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@shuraka.app

# ─────────────────────────────────────────────────────────────
# Apple Wallet — Pass Kit Integration
# الحصول عليها من: Apple Developer Account → Certificates
# https://developer.apple.com/account/
# ─────────────────────────────────────────────────────────────
# APPLE_WALLET_PASS_TYPE_ID=pass.app.shuraka.loyalty
# APPLE_WALLET_TEAM_ID=YOUR_APPLE_TEAM_ID
# APPLE_WALLET_CERTIFICATE=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# APPLE_WALLET_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# APPLE_WALLET_WEB_SERVICE_URL=https://api.shuraka.app/wallet
EXPO_PUBLIC_APPLE_WALLET_ENDPOINT=

# ─────────────────────────────────────────────────────────────
# Google Wallet — Loyalty Pass Integration
# الحصول عليها من: Google Cloud Console → Google Wallet API
# https://console.cloud.google.com/
# ─────────────────────────────────────────────────────────────
# GOOGLE_WALLET_ISSUER_ID=your_google_wallet_issuer_id
# GOOGLE_WALLET_CLASS_ID=your_loyalty_class_id
# GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_WALLET_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
EXPO_PUBLIC_GOOGLE_WALLET_ENDPOINT=

# ─────────────────────────────────────────────────────────────
# الجلسات والأمان
# ─────────────────────────────────────────────────────────────
# AUTH_SECRET=your_random_64_char_secret_here
# SESSION_SECRET=your_random_64_char_secret_here

# لتوليد قيمة عشوائية:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─────────────────────────────────────────────────────────────
# Google OAuth (اختياري)
# الحصول عليها من: console.cloud.google.com → Credentials → OAuth 2.0
# ─────────────────────────────────────────────────────────────
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your_google_web_client_id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_google_ios_client_id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_google_android_client_id.apps.googleusercontent.com

# ─────────────────────────────────────────────────────────────
# Push Notifications (اختياري)
# ─────────────────────────────────────────────────────────────
# FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id

# ─────────────────────────────────────────────────────────────
# بيئة التطوير
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production

# ─────────────────────────────────────────────────────────────
# ملاحظات مهمة:
# 1. أضف .env إلى .gitignore (لا ترفعه على GitHub أبدًا)
# 2. المتغيرات التي تبدأ بـ EXPO_PUBLIC_ مرئية في Frontend
# 3. المتغيرات الأخرى للاستخدام في Edge Functions فقط
# 4. في Supabase: أضف المتغيرات السرية عبر Dashboard → Edge Functions → Secrets
# ─────────────────────────────────────────────────────────────
